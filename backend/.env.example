# ============================================================
#  Variables d'environnement — Backend NestJS
#  Copiez ce fichier en .env et adaptez les valeurs.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
SWAGGER_PATH=docs

# --- Base de données PostgreSQL (Prisma) ---
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://transport:transport@localhost:5432/transport_db?schema=public

# Variables utilisées par docker-compose pour le service postgres
POSTGRES_USER=transport
POSTGRES_PASSWORD=transport
POSTGRES_DB=transport_db
POSTGRES_PORT=5432

# --- Authentification JWT ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=*

# ============================================================
#  Variables d'installation — Seed du premier ADMIN_GENERAL
#
#  Ces variables sont utilisées UNE SEULE FOIS lors de
#  l'initialisation du système (npm run db:seed).
#  Elles ne sont pas utilisées par l'application en production.
# ============================================================
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ============================================================
#  Variables de test local — Scripts d'acceptation Phase 7, 8, 9, 10, 11 & 12
#
#  Ces variables sont uniquement destinées aux scripts de
#  vérification locale (scripts/test-http-phase7.js, test-http-phase8.js, test-http-phase9.js, test-http-phase10.js, test-http-phase11.js & test-http-phase12.js).
#  Elles ne me sont PAS utilisées par l'application.
#  Ne pas définir dans un environnement de production.
# ============================================================
PHASE7_ADMIN_EMAIL=
PHASE7_ADMIN_PASSWORD=

PHASE8_ADMIN_EMAIL=
PHASE8_ADMIN_PASSWORD=

PHASE9_ADMIN_EMAIL=
PHASE9_ADMIN_PASSWORD=

PHASE10_ADMIN_EMAIL=
PHASE10_ADMIN_PASSWORD=

PHASE11_ADMIN_EMAIL=
PHASE11_ADMIN_PASSWORD=

PHASE12_ADMIN_EMAIL=
PHASE12_ADMIN_PASSWORD=
